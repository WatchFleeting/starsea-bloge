<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>番茄钟</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        * { margin:0; padding:0; box-sizing:border-box; }
        body { background:#111827; color:#eef5ff; font-family: 'Segoe UI', system-ui; display:flex; align-items:center; justify-content:center; height:100vh; }
        .container { text-align:center; width:100%; padding:20px; }
        .time { font-size:4rem; font-weight:700; font-family:monospace; color:#66ccff; text-shadow:0 0 10px rgba(102,204,255,0.3); }
        .btn { background:rgba(27,37,55,0.7); border:1px solid #39C5BB; color:#66ccff; padding:8px 16px; border-radius:8px; cursor:pointer; margin:5px; }
        .btn:hover { background:rgba(57,197,187,0.3); color:white; }
        .status { font-size:0.85rem; color:#bbd4ff; margin:10px 0; }
        input { width:60px; background:#1e2a3c; border:1px solid #39C5BB; color:#fff; border-radius:6px; text-align:center; padding:4px; }
    </style>
</head>
<body>
<div class="container">
    <div class="time" id="display">25:00</div>
    <div class="status" id="status">准备开始</div>
    <div>
        <button class="btn" id="start"><i class="fa fa-play"></i> 开始</button>
        <button class="btn" id="pause"><i class="fa fa-pause"></i> 暂停</button>
        <button class="btn" id="reset"><i class="fa fa-redo"></i> 重置</button>
    </div>
    <div style="margin-top:15px;">
        <label>专注时长 (分钟)</label>
        <input type="number" id="minutes" value="25" min="1" max="120">
    </div>
</div>
<script>
    let timer, seconds = 25*60;
    const display = document.getElementById('display'),
          status = document.getElementById('status'),
          start = document.getElementById('start'),
          pause = document.getElementById('pause'),
          reset = document.getElementById('reset'),
          minInput = document.getElementById('minutes');
    function update(){ display.textContent = `${Math.floor(seconds/60).toString().padStart(2,'0')}:${(seconds%60).toString().padStart(2,'0')}`; }
    start.onclick = ()=>{ if(timer) return; status.textContent='专注中...'; timer = setInterval(()=>{ if(seconds<=0){ clearInterval(timer); timer=null; status.textContent='时间到！'; alert('番茄钟完成！'); return; } seconds--; update(); },1000); }
    pause.onclick = ()=>{ clearInterval(timer); timer=null; status.textContent='已暂停'; }
    reset.onclick = ()=>{ clearInterval(timer); timer=null; seconds = parseInt(minInput.value)*60; update(); status.textContent='准备开始'; }
    minInput.onchange = ()=>{ reset.onclick(); }
    update();
</script>
</body>
</html>